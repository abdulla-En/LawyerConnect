# COMPLETE WORKFLOW TEST
###############################################

### 55. Complete Workflow: Register -> Login -> Create Booking -> Create Payment -> Confirm Payment
### Step 1: Register New User
POST {{LawyerConnect_HostAddress}}/api/auth/register
Content-Type: {{ContentType}}

{
  "fullName": "Workflow Test User",
  "email": "workflow@test.com",
  "password": "TestPass123!",
  "phone": "+1999999999",
  "city": "Test City"
}

### Step 2: Login
POST {{LawyerConnect_HostAddress}}/api/auth/login
Content-Type: {{ContentType}}

{
  "email": "workflow@test.com",
  "password": "TestPass123!"
}

### Step 3: Get Current User Info
GET {{LawyerConnect_HostAddress}}/api/auth/me
Authorization: Bearer {{UserToken}}

### Step 4: Register as Lawyer (userId extracted from token)
POST {{LawyerConnect_HostAddress}}/api/lawyers/register
Authorization: Bearer {{UserToken}}
Content-Type: {{ContentType}}

{
  "specialization": "Test Law",
  "experienceYears": 3,
  "price": 100.00,
  "address": "Test Address",
  "latitude": 0.0,
  "longitude": 0.0
}

### Step 5: Create Booking
POST {{LawyerConnect_HostAddress}}/api/bookings
Authorization: Bearer {{UserToken}}
Content-Type: {{ContentType}}

{
  "lawyerId": {{LawyerId}},
  "date": "2024-12-30T10:00:00Z"
}

### Step 6: Create Payment Session
POST {{LawyerConnect_HostAddress}}/api/payments/create-session
Authorization: Bearer {{UserToken}}
Content-Type: {{ContentType}}

{
  "bookingId": {{BookingId}},
  "amount": 100.00,
  "provider": "TestProvider"
}

### Step 7: Confirm Payment
POST {{LawyerConnect_HostAddress}}/api/payments/confirm
Authorization: Bearer {{UserToken}}
Content-Type: {{ContentType}}

{
  "sessionId": {{PaymentSessionId}},
  "providerSessionId": "test_provider_session_12345"
}

###############################################
# NOTES
###############################################
# 
# IMPORTANT: 
# 1. After running login requests (4, 5, 6), copy the token from the response
#    and paste it into the variables at the top (@UserToken, @LawyerToken, @AdminToken)
# 
# 2. After creating a lawyer (19), copy the lawyer ID from the response
#    and update @LawyerId variable
#
# 3. After creating a booking (29), copy the booking ID from the response
#    and update @BookingId variable
#
# 4. After creating a payment session (43), copy the session ID from the response
#    and update @PaymentSessionId variable
#
# 5. The UserId should be extracted from the JWT token or from the /api/auth/me response
#
# 6. Rate limiting is set to 5 requests per 60 seconds per IP+Path combination
#    Check X-RateLimit-* headers in responses
#
# 7. All endpoints that require authentication will return 401 if token is missing/invalid
#
# 8. Admin-only endpoints will return 403 if user doesn't have Admin role
#
###############################################
